<Window x:Class="GsmCalculator.Views.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:GsmCalculator.Helpers"
        mc:Ignorable="d"
        Title="{Binding Name}"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Width="300"
        Icon="/Resources/app.ico"
        Background="{DynamicResource WindowBackground}">

    <Window.Resources>
        <Style x:Key="ConvButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="helpers:ButtonProps.CornerRadius" Value="3"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
        </Style>

        <Style x:Key="LtoKgStyle" TargetType="Button" BasedOn="{StaticResource ConvButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource WidgetToKgBackground}"/>
        </Style>

        <Style x:Key="KgToLStyle" TargetType="Button" BasedOn="{StaticResource ConvButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource WidgetToLBackground}"/>
        </Style>

        <Style x:Key="InsertButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="helpers:ButtonProps.CornerRadius" Value="3"/>
            <Setter Property="Background" Value="{DynamicResource TopBarButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TopBarButtonForeground}"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="12">

        <!-- Плотность -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{DynamicResource Widget_Density}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>

            <TextBox Grid.Column="1"
                     Text="{Binding DensityText, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="{Binding IsDensityReadOnly}"
                     Background="{DynamicResource ControlBackground}"
                     Foreground="{DynamicResource ControlForeground}"
                     FontFamily="Consolas" FontSize="14"
                     Padding="4,2"/>
        </Grid>

        <!-- Округление — ползунок 0..3 -->
        <TextBlock Text="{DynamicResource Widget_DecimalPlaces}" Margin="0,0,0,4"/>
        <DockPanel Margin="0,0,0,12">
            <TextBlock DockPanel.Dock="Right" Width="22" TextAlignment="Right"
                       FontWeight="Bold" Text="{Binding DecimalPlaces}"/>
            <Slider Minimum="0" Maximum="3"
                    Value="{Binding DecimalPlaces, Mode=TwoWay}"
                    IsSnapToTickEnabled="True" TickFrequency="1"
                    VerticalAlignment="Center" Margin="0,0,8,0"/>
        </DockPanel>

        <!-- Кнопки конвертации -->
        <Button Content="{DynamicResource Widget_LtoKg}"
                Style="{StaticResource LtoKgStyle}"
                Command="{Binding LitersToKgCommand}"/>

        <Button Content="{DynamicResource Widget_KgToL}"
                Style="{StaticResource KgToLStyle}"
                Command="{Binding KgToLitersCommand}"
                Margin="0,0,0,12"/>

        <!-- Результат -->
        <Border Background="{DynamicResource WidgetResultBackground}"
                BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1"
                Padding="8" Margin="0,0,0,8" CornerRadius="3">
            <TextBlock Text="{Binding LastResult}"
                       TextWrapping="Wrap"
                       MinHeight="36"
                       FontFamily="Consolas" FontSize="13"/>
        </Border>

        <!-- Вставить в калькулятор -->
        <Button Content="{DynamicResource Widget_Insert}"
                Style="{StaticResource InsertButtonStyle}"
                Command="{Binding InsertToCalculatorCommand}"/>

    </StackPanel>
</Window>
