<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============ ENGLISH ============
         Every key must also exist in Strings.ru.xaml. -->

    <!-- Common -->
    <sys:String x:Key="Common_OK">OK</sys:String>
    <sys:String x:Key="Common_Cancel">Cancel</sys:String>
    <sys:String x:Key="Common_Save">Save</sys:String>
    <sys:String x:Key="Common_Error">Error</sys:String>
    <sys:String x:Key="Common_ErrorFormat">Error: {0}</sys:String>
    <sys:String x:Key="Common_Yes">Yes</sys:String>
    <sys:String x:Key="Common_No">No</sys:String>

    <!-- Startup dialog (continue session) -->
    <sys:String x:Key="Session_ContinueTitle">Continue session?</sys:String>
    <sys:String x:Key="Session_ContinuePrompt">Restore the previous session?&#10;The display, calculation history and open widgets will be restored.</sys:String>
    <sys:String x:Key="Session_SavedAt">Saved: {0}</sys:String>

    <!-- Main window -->
    <sys:String x:Key="Main_AddWidget">Add widget</sys:String>
    <sys:String x:Key="Main_Settings">Settings</sys:String>
    <sys:String x:Key="Main_History">History</sys:String>
    <sys:String x:Key="Main_HideHistory">Hide history</sys:String>
    <sys:String x:Key="Main_ShowHistory">Show history</sys:String>

    <!-- Widget -->
    <sys:String x:Key="Widget_Density">Density:</sys:String>
    <sys:String x:Key="Widget_DecimalPlaces">Decimal places:</sys:String>
    <sys:String x:Key="Widget_LtoKg">L → kg</sys:String>
    <sys:String x:Key="Widget_KgToL">kg → L</sys:String>
    <sys:String x:Key="Widget_Insert">Insert into calculator</sys:String>
    <sys:String x:Key="Widget_ResultLtoKg">{0} L × {1} = {2} kg</sys:String>
    <sys:String x:Key="Widget_ResultKgToL">{0} kg ÷ {1} = {2} L</sys:String>
    <sys:String x:Key="Widget_ErrorDensityPositive">Density must be greater than zero.</sys:String>

    <!-- Settings -->
    <sys:String x:Key="Settings_Title">Settings</sys:String>
    <sys:String x:Key="Settings_HistorySize">Calculation history size</sys:String>
    <sys:String x:Key="Settings_Theme">Color theme</sys:String>
    <sys:String x:Key="Settings_Startup">Startup behavior</sys:String>
    <sys:String x:Key="Settings_Language">Interface language</sys:String>
    <sys:String x:Key="Settings_CalcMode">Calculator mode</sys:String>
    <sys:String x:Key="Settings_ThemeLight">Light</sys:String>
    <sys:String x:Key="Settings_ThemeDark">Dark</sys:String>
    <sys:String x:Key="Settings_ThemeBlue">Blue</sys:String>
    <sys:String x:Key="Settings_StartupAsk">Always ask</sys:String>
    <sys:String x:Key="Settings_StartupContinue">Always continue last session</sys:String>
    <sys:String x:Key="Settings_StartupFresh">Always start fresh</sys:String>
    <sys:String x:Key="Settings_LangRu">Русский</sys:String>
    <sys:String x:Key="Settings_LangEn">English</sys:String>
    <sys:String x:Key="Settings_ModeClassic">Classic (left to right)</sys:String>
    <sys:String x:Key="Settings_ModeEngineering">Engineering (× ÷ precedence)</sys:String>

    <!-- Add widget window -->
    <sys:String x:Key="AddWidget_Title">Add widget</sys:String>
    <sys:String x:Key="AddWidget_Available">Available widgets</sys:String>
    <sys:String x:Key="AddWidget_Open">Open</sys:String>
    <sys:String x:Key="AddWidget_Edit">Edit</sys:String>
    <sys:String x:Key="AddWidget_CreateNew">Create new…</sys:String>
    <sys:String x:Key="AddWidget_Delete">Delete</sys:String>
    <sys:String x:Key="AddWidget_DeleteTitle">Delete widget</sys:String>
    <sys:String x:Key="AddWidget_DeleteConfirm">Delete widget "{0}"?&#10;This action cannot be undone.</sys:String>

    <!-- Widget list item -->
    <sys:String x:Key="WidgetItem_FixedDensity">Fixed density: {0}</sys:String>
    <sys:String x:Key="WidgetItem_VariableDensity">Variable density (default {0})</sys:String>
    <sys:String x:Key="WidgetItem_BuiltIn">built-in</sys:String>
    <sys:String x:Key="WidgetItem_Custom">custom</sys:String>

    <!-- Create widget window -->
    <sys:String x:Key="CreateWidget_Title">Create widget</sys:String>
    <sys:String x:Key="CreateWidget_TitleEdit">Edit widget</sys:String>
    <sys:String x:Key="CreateWidget_Name">Name</sys:String>
    <sys:String x:Key="CreateWidget_DensityType">Density type</sys:String>
    <sys:String x:Key="CreateWidget_Fixed">Fixed</sys:String>
    <sys:String x:Key="CreateWidget_Variable">Variable</sys:String>
    <sys:String x:Key="CreateWidget_DefaultDensity">Default density</sys:String>
    <sys:String x:Key="CreateWidget_DecimalPlaces">Decimal places</sys:String>
    <sys:String x:Key="CreateWidget_ValidationName">Enter a widget name.</sys:String>
    <sys:String x:Key="CreateWidget_ValidationDensityNumber">Density must be a number (use a dot as the separator).</sys:String>
    <sys:String x:Key="CreateWidget_ValidationDensityPositive">Density must be greater than zero.</sys:String>

</ResourceDictionary>
