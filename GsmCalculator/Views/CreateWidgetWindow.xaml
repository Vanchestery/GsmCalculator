<Window x:Class="GsmCalculator.Views.CreateWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:GsmCalculator.Helpers"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="380"
        WindowStartupLocation="CenterOwner"
        Icon="/Resources/app.ico"
        Background="{DynamicResource WindowBackground}">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>

        <Style x:Key="DialogButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Padding" Value="0,9"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="helpers:ButtonProps.CornerRadius" Value="3"/>
            <Setter Property="Background" Value="{DynamicResource TopBarButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TopBarButtonForeground}"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">

        <!-- Название -->
        <TextBlock Style="{StaticResource SectionLabel}" Margin="0,0,0,4" Text="{DynamicResource CreateWidget_Name}"/>
        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                 Background="{DynamicResource ControlBackground}"
                 Foreground="{DynamicResource ControlForeground}"
                 FontSize="14" Padding="4,3"/>

        <!-- Тип плотности.
             GroupName не используем — взаимоисключение обеспечивает
             зеркальная логика IsFixedDensity / IsVariableDensity во ViewModel. -->
        <TextBlock Style="{StaticResource SectionLabel}" Text="{DynamicResource CreateWidget_DensityType}"/>
        <StackPanel Orientation="Horizontal">
            <RadioButton Content="{DynamicResource CreateWidget_Fixed}"
                         IsChecked="{Binding IsFixedDensity}" Margin="0,0,20,0"/>
            <RadioButton Content="{DynamicResource CreateWidget_Variable}"
                         IsChecked="{Binding IsVariableDensity}"/>
        </StackPanel>

        <!-- Плотность по умолчанию -->
        <TextBlock Style="{StaticResource SectionLabel}" Text="{DynamicResource CreateWidget_DefaultDensity}"/>
        <TextBox Text="{Binding DensityText, UpdateSourceTrigger=PropertyChanged}"
                 Background="{DynamicResource ControlBackground}"
                 Foreground="{DynamicResource ControlForeground}"
                 FontFamily="Consolas" FontSize="14" Padding="4,3"/>

        <!-- Округление — ползунок 0..3 -->
        <TextBlock Style="{StaticResource SectionLabel}" Text="{DynamicResource CreateWidget_DecimalPlaces}"/>
        <DockPanel>
            <TextBlock DockPanel.Dock="Right" Width="28" TextAlignment="Right"
                       FontWeight="Bold" Text="{Binding DecimalPlaces}"/>
            <Slider Minimum="0" Maximum="3"
                    Value="{Binding DecimalPlaces, Mode=TwoWay}"
                    IsSnapToTickEnabled="True" TickFrequency="1"
                    VerticalAlignment="Center" Margin="0,0,8,0"/>
        </DockPanel>

        <!-- Чекбокс «В избранное» — закреплять виджет на панели главного окна. -->
        <CheckBox Content="{DynamicResource CreateWidget_IsFavorite}"
                  IsChecked="{Binding IsFavorite}"
                  Foreground="{DynamicResource TextForeground}"
                  Margin="0,12,0,0"/>

        <!-- Сообщение валидации -->
        <TextBlock Text="{Binding ValidationMessage}"
                   Foreground="#FFEF5350"
                   FontSize="11" TextWrapping="Wrap"
                   Margin="0,12,0,0"/>

        <!-- Кнопки -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{DynamicResource Common_Save}" Style="{StaticResource DialogButton}"
                    Command="{Binding SaveCommand}" IsDefault="True"/>
            <Button Content="{DynamicResource Common_Cancel}" Style="{StaticResource DialogButton}"
                    Command="{Binding CancelCommand}" IsCancel="True"/>
        </StackPanel>

    </StackPanel>
</Window>
