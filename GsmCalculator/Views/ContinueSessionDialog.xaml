<Window x:Class="GsmCalculator.Views.ContinueSessionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:GsmCalculator.Helpers"
        mc:Ignorable="d"
        Title="{DynamicResource Session_ContinueTitle}"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="430"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/app.ico"
        Background="{DynamicResource WindowBackground}">

    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Padding" Value="0,9"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="helpers:ButtonProps.CornerRadius" Value="3"/>
            <Setter Property="Background" Value="{DynamicResource TopBarButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TopBarButtonForeground}"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">

        <!-- Текст вопроса -->
        <TextBlock Text="{DynamicResource Session_ContinuePrompt}"
                   Foreground="{DynamicResource TextForeground}"
                   FontSize="13" TextWrapping="Wrap"/>

        <!-- Когда сессия была сохранена (заполняется из code-behind) -->
        <TextBlock x:Name="SavedAtText"
                   Foreground="{DynamicResource SecondaryForeground}"
                   FontSize="11" Margin="0,10,0,0"/>

        <!-- Кнопки -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="{DynamicResource Common_Yes}"
                    Style="{StaticResource DialogButton}"
                    IsDefault="True" Click="OnYes"/>
            <Button Content="{DynamicResource Common_No}"
                    Style="{StaticResource DialogButton}"
                    IsCancel="True"/>
        </StackPanel>

    </StackPanel>
</Window>
