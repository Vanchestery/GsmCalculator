<Window x:Class="GsmCalculator.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:GsmCalculator.Helpers"
        mc:Ignorable="d"
        Title="{DynamicResource Settings_Title}"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="440"
        WindowStartupLocation="CenterOwner"
        Icon="/Resources/app.ico"
        Background="{DynamicResource WindowBackground}">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>

        <Style x:Key="DialogButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Padding" Value="0,9"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="helpers:ButtonProps.CornerRadius" Value="3"/>
            <Setter Property="Background" Value="{DynamicResource TopBarButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TopBarButtonForeground}"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="16">

        <!-- Размер истории вычислений -->
        <TextBlock Style="{StaticResource SectionLabel}" Margin="0,0,0,4"
                   Text="{DynamicResource Settings_HistorySize}"/>
        <DockPanel>
            <TextBlock DockPanel.Dock="Right" Width="34" TextAlignment="Right"
                       FontWeight="Bold" Text="{Binding HistorySize}"/>
            <Slider Minimum="{Binding HistorySizeMin}" Maximum="{Binding HistorySizeMax}"
                    Value="{Binding HistorySize}"
                    IsSnapToTickEnabled="True" TickFrequency="1"
                    VerticalAlignment="Center" Margin="0,0,8,0"/>
        </DockPanel>

        <!-- Цветовая тема -->
        <TextBlock Style="{StaticResource SectionLabel}" Text="{DynamicResource Settings_Theme}"/>
        <ComboBox ItemsSource="{Binding ThemeOptions}"
                  SelectedValuePath="Value" DisplayMemberPath="Label"
                  SelectedValue="{Binding Theme}"/>

        <!-- Поведение при запуске -->
        <TextBlock Style="{StaticResource SectionLabel}" Text="{DynamicResource Settings_Startup}"/>
        <ComboBox ItemsSource="{Binding StartupOptions}"
                  SelectedValuePath="Value" DisplayMemberPath="Label"
                  SelectedValue="{Binding StartupBehavior}"/>

        <!-- Язык интерфейса -->
        <TextBlock Style="{StaticResource SectionLabel}" Text="{DynamicResource Settings_Language}"/>
        <ComboBox ItemsSource="{Binding LanguageOptions}"
                  SelectedValuePath="Value" DisplayMemberPath="Label"
                  SelectedValue="{Binding Language}"/>

        <!-- Режим калькулятора -->
        <TextBlock Style="{StaticResource SectionLabel}" Text="{DynamicResource Settings_CalcMode}"/>
        <ComboBox ItemsSource="{Binding CalculatorModeOptions}"
                  SelectedValuePath="Value" DisplayMemberPath="Label"
                  SelectedValue="{Binding CalculatorMode}"/>

        <!-- Кнопки OK / Отмена -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="{DynamicResource Common_OK}" Style="{StaticResource DialogButton}"
                    Command="{Binding OkCommand}" IsDefault="True"/>
            <Button Content="{DynamicResource Common_Cancel}" Style="{StaticResource DialogButton}"
                    Command="{Binding CancelCommand}" IsCancel="True"/>
        </StackPanel>

    </StackPanel>
</Window>
