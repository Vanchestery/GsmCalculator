<Window x:Class="GsmCalculator.Views.AddWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:GsmCalculator.Helpers"
        mc:Ignorable="d"
        Title="{DynamicResource AddWidget_Title}"
        WindowStyle="ToolWindow"
        Topmost="True"
        ShowInTaskbar="False"
        Width="410" Height="500"
        MinWidth="360" MinHeight="380"
        Icon="/Resources/app.ico"
        Background="{DynamicResource WindowBackground}">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
        </Style>

        <Style x:Key="DialogButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="helpers:ButtonProps.CornerRadius" Value="3"/>
            <Setter Property="Background" Value="{DynamicResource TopBarButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TopBarButtonForeground}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{DynamicResource AddWidget_Available}" FontWeight="Bold"
                   FontSize="14" Margin="0,0,0,8"/>

        <!-- Список виджетов -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1" CornerRadius="3">
            <ListBox ItemsSource="{Binding Widgets}"
                     SelectedItem="{Binding SelectedWidget}"
                     Background="{DynamicResource WindowBackground}"
                     BorderThickness="0"
                     MouseDoubleClick="OnWidgetDoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <!-- Foreground задаём явно: ListBoxItem.ControlTemplate
                                     по умолчанию устанавливает Foreground=SystemColors.ControlText
                                     (чёрный), что перебивает неявный стиль TextBlock
                                     для DynamicResource TextForeground. -->
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{DynamicResource TextForeground}"
                                           FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="{Binding DensityInfo}"
                                           Foreground="{DynamicResource SecondaryForeground}"
                                           FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding KindLabel}"
                                       Foreground="{DynamicResource SecondaryForeground}"
                                       FontSize="10" VerticalAlignment="Center"
                                       Margin="8,0,4,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="{DynamicResource AddWidget_Open}" Style="{StaticResource DialogButton}"
                    Command="{Binding OpenWidgetCommand}"/>
            <Button Content="{DynamicResource AddWidget_CreateNew}" Style="{StaticResource DialogButton}"
                    Command="{Binding CreateWidgetCommand}"/>
            <Button Content="{DynamicResource AddWidget_Delete}" Style="{StaticResource DialogButton}"
                    Command="{Binding DeleteWidgetCommand}"/>
        </StackPanel>
    </Grid>
</Window>
