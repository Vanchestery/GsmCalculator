<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ ТЁМНАЯ ТЕМА ============ -->
    <!-- Тот же набор ключей что и в LightTheme.xaml, другие цвета. -->

    <!-- Общее -->
    <SolidColorBrush x:Key="WindowBackground"        Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="TextForeground"          Color="#FFEEEEEE"/>
    <SolidColorBrush x:Key="SecondaryForeground"     Color="#FFAAAAAA"/>
    <SolidColorBrush x:Key="PanelBackground"         Color="#FF3E3E42"/>
    <SolidColorBrush x:Key="PanelBorderBrush"        Color="#FF555555"/>
    <SolidColorBrush x:Key="ControlBackground"       Color="#FF3E3E42"/>
    <SolidColorBrush x:Key="ControlForeground"       Color="#FFEEEEEE"/>

    <!-- Дисплей -->
    <SolidColorBrush x:Key="DisplayBackground"        Color="#FF1A1A1A"/>
    <SolidColorBrush x:Key="DisplayForeground"        Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="DisplayPreviewForeground" Color="#FF999999"/>

    <!-- Кнопки калькулятора -->
    <SolidColorBrush x:Key="DigitButtonBackground"      Color="#FF3E3E42"/>
    <SolidColorBrush x:Key="DigitButtonForeground"      Color="#FFEEEEEE"/>
    <SolidColorBrush x:Key="OperationButtonBackground"  Color="#FF5A4A2F"/>
    <SolidColorBrush x:Key="OperationButtonForeground"  Color="#FFFFD180"/>
    <SolidColorBrush x:Key="EqualsButtonBackground"     Color="#FF388E3C"/>
    <SolidColorBrush x:Key="EqualsButtonForeground"     Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="UtilButtonBackground"       Color="#FF5A2F2F"/>
    <SolidColorBrush x:Key="UtilButtonForeground"       Color="#FFFFCDD2"/>
    <SolidColorBrush x:Key="TopBarButtonBackground"     Color="#FF454548"/>
    <SolidColorBrush x:Key="TopBarButtonForeground"     Color="#FFEEEEEE"/>

    <!-- Виджеты -->
    <SolidColorBrush x:Key="WidgetToKgBackground"   Color="#FF2C4A6E"/>
    <SolidColorBrush x:Key="WidgetToLBackground"    Color="#FF2E5430"/>
    <SolidColorBrush x:Key="WidgetResultBackground" Color="#FF1A1A1A"/>

</ResourceDictionary>
